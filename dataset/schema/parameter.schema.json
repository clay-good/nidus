{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/clay-good/nidus/dataset/schema/parameter.schema.json",
  "title": "Nidus Parameter",
  "description": "A single physiological parameter with provenance, value, optional trajectory, and confidence tier.",
  "type": "object",
  "required": [
    "id",
    "name",
    "subsystem",
    "value",
    "tier",
    "tier_rationale",
    "citations",
    "extraction"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Dotted identifier: <subsystem_group>.<category>.<variable>.<aspect>",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "description": "Human-readable name."
    },
    "subsystem": {
      "type": "string",
      "enum": [
        "maternal_cardiovascular",
        "maternal_blood",
        "maternal_respiratory",
        "maternal_renal",
        "maternal_endocrine",
        "placental_structure",
        "placental_gas_exchange",
        "placental_glucose",
        "placental_endocrine",
        "fetal_circulation",
        "fetal_growth",
        "fetal_metabolism",
        "amniotic_fluid"
      ]
    },
    "category": {
      "type": "string",
      "description": "Optional finer-grained category within the subsystem."
    },
    "value": {
      "type": "object",
      "required": ["central", "units"],
      "additionalProperties": false,
      "properties": {
        "central": {
          "type": "number",
          "description": "Best central estimate."
        },
        "low": {
          "type": "number",
          "description": "Lower bound (e.g. CI low)."
        },
        "high": {
          "type": "number",
          "description": "Upper bound (e.g. CI high)."
        },
        "units": {
          "type": "string",
          "description": "SI or domain-conventional units, e.g. 'L/min', 'mmHg', 'g'."
        },
        "distribution": {
          "type": "string",
          "enum": ["normal", "lognormal", "uniform", "empirical"]
        },
        "ci": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence interval level for low/high, e.g. 0.95."
        }
      }
    },
    "trajectory": {
      "type": "object",
      "description": "Optional gestational-age-dependent trajectory.",
      "required": ["type", "params"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "constant",
            "linear",
            "polynomial",
            "gaussian",
            "logistic",
            "exponential",
            "piecewise"
          ]
        },
        "params": {
          "type": "object",
          "description": "Form-specific parameters."
        },
        "valid_range_weeks": {
          "type": "array",
          "items": {"type": "number", "minimum": 0, "maximum": 45},
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "tier": {
      "type": "string",
      "enum": ["A", "B", "C", "D"]
    },
    "tier_rationale": {
      "type": "string",
      "minLength": 10,
      "description": "Why this tier was assigned. Must reference the evidence base."
    },
    "citations": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "description": "Citation keys; must resolve to entries in dataset/citations/citations.json."
    },
    "primary_citation": {
      "type": "string",
      "description": "Optional. The single most load-bearing citation. Must be present in 'citations'."
    },
    "extraction": {
      "type": "object",
      "required": ["review_status"],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "description": "How the value was extracted, e.g. 'table_2_column_3', 'figure_4_digitised'."
        },
        "by": {
          "type": "string",
          "description": "Who extracted the value."
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "review_status": {
          "type": "string",
          "enum": ["unverified", "pending_human_review", "verified", "contested"],
          "description": "unverified = illustrative central value, no source confirmation yet; pending_human_review = the stored value was located in a real source by automated review (see source_check) but no human has signed off; verified = a human confirmed it against the source; contested = flagged for investigation."
        },
        "reviewer": {
          "type": ["string", "null"]
        },
        "source_check": {
          "type": "object",
          "description": "Provenance for an automated pre-verification. Present when review_status is pending_human_review. Records what automated review found in the cited source; never implies human verification.",
          "additionalProperties": false,
          "required": ["verdict", "evidence_level", "source_citation", "checked_by"],
          "properties": {
            "verdict": {
              "type": "string",
              "enum": ["match", "close"]
            },
            "evidence_level": {
              "type": "string",
              "enum": ["fulltext", "abstract", "secondary", "regulatory", "preprint", "biomodels"]
            },
            "source_citation": {
              "type": "string",
              "description": "Citation key the evidence was drawn from (the parameter's own primary citation for fulltext/abstract verdicts; a short source label for secondary/regulatory/preprint evidence)."
            },
            "source_url": {
              "type": "string",
              "description": "Optional DOI/URL of the evidence source, used when the evidence is a secondary/regulatory/preprint source not in citations.json."
            },
            "quote": {
              "type": "string",
              "description": "Verbatim supporting quote from the source."
            },
            "extracted_value": {
              "type": "string",
              "description": "What the source reports for this quantity."
            },
            "checked_by": {
              "type": "string",
              "description": "The automated reviewer, e.g. 'machine-preverify'."
            },
            "checked_date": {
              "type": "string",
              "format": "date"
            }
          }
        }
      }
    },
    "applicability": {
      "type": "object",
      "description": "Population the parameter applies to and known exclusions.",
      "properties": {
        "population": {"type": "string"},
        "excludes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "Caveats, modelling notes, extrapolation warnings."
    }
  },
  "additionalProperties": false
}
