{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/claygood/nidus/dataset/schema/citation.schema.json",
  "title": "Nidus Citation",
  "description": "A single bibliographic record. Journal articles, preprints, and conference papers SHOULD have a DOI, PMID, or URL; books and pre-DOI references may resolve by author + title + year only. The README rule that Tier A/B parameters must link to a DOI/PMID is enforced at the parameter level by CI, not by this schema.",
  "type": "object",
  "required": ["key", "type", "title", "authors", "year"],
  "properties": {
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]+$",
      "description": "Citation key, e.g. 'mahendru-2014-cardiac-output' or 'sanghavi2014b'. Kebab-case with descriptive suffix is permitted; snake_case is also accepted."
    },
    "type": {
      "type": "string",
      "enum": [
        "journal-article",
        "book",
        "book-chapter",
        "conference-paper",
        "preprint",
        "report",
        "dataset",
        "thesis"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "authors": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "description": "Each author as 'Family, Given'."
    },
    "year": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2100
    },
    "journal": {"type": "string"},
    "volume": {"type": ["integer", "string"]},
    "issue": {"type": ["integer", "string"]},
    "pages": {"type": "string"},
    "publisher": {"type": "string"},
    "doi": {
      "type": "string",
      "description": "Bare DOI, no URL prefix."
    },
    "pmid": {"type": ["integer", "string"]},
    "url": {
      "type": "string",
      "format": "uri"
    },
    "open_access": {"type": "boolean"},
    "isbn": {"type": "string"},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
