<?xml version="1.0" encoding="UTF-8"?>
<!--
  PhysiCell settings for the nidus placental-villous slice example.

  All biological constants are read from <user_parameters>, which is
  generated by `nidus export --format physiocell`. Each parameter
  element carries a `nidus:` namespaced description with the citation
  key + confidence tier so reviewers can audit provenance directly
  from this file.
-->
<PhysiCell_settings version="1.13.0">

  <domain>
    <x_min>-75</x_min>
    <x_max>75</x_max>
    <y_min>-75</y_min>
    <y_max>75</y_max>
    <z_min>-10</z_min>
    <z_max>10</z_max>
    <dx>5</dx>
    <dy>5</dy>
    <dz>20</dz>
    <use_2D>true</use_2D>
  </domain>

  <overall>
    <max_time units="min">360</max_time>
    <time_units>min</time_units>
    <space_units>micron</space_units>
    <dt_diffusion units="min">0.01</dt_diffusion>
    <dt_mechanics units="min">0.1</dt_mechanics>
    <dt_phenotype units="min">6</dt_phenotype>
  </overall>

  <parallel>
    <omp_num_threads>4</omp_num_threads>
  </parallel>

  <save>
    <folder>output</folder>
    <full_data>
      <interval units="min">30</interval>
      <enable>true</enable>
    </full_data>
    <SVG>
      <interval units="min">30</interval>
      <enable>true</enable>
    </SVG>
    <legacy_data>
      <enable>false</enable>
    </legacy_data>
  </save>

  <options>
    <legacy_random_points_on_sphere_in_divide>false</legacy_random_points_on_sphere_in_divide>
    <virtual_wall_at_domain_edge>true</virtual_wall_at_domain_edge>
  </options>

  <microenvironment_setup>
    <variable name="oxygen" units="mmHg" ID="0">
      <physical_parameter_set>
        <diffusion_coefficient units="micron^2/min">100000.0</diffusion_coefficient>
        <decay_rate units="1/min">0.1</decay_rate>
      </physical_parameter_set>
      <initial_condition units="mmHg">40.0</initial_condition>
      <Dirichlet_boundary_condition units="mmHg" enabled="true">40.0</Dirichlet_boundary_condition>
    </variable>
    <variable name="glucose" units="mmol/L" ID="1">
      <physical_parameter_set>
        <diffusion_coefficient units="micron^2/min">36000.0</diffusion_coefficient>
        <decay_rate units="1/min">0.0</decay_rate>
      </physical_parameter_set>
      <initial_condition units="mmol/L">5.0</initial_condition>
      <Dirichlet_boundary_condition units="mmol/L" enabled="true">5.0</Dirichlet_boundary_condition>
    </variable>
    <options>
      <calculate_gradients>true</calculate_gradients>
      <track_internalized_substrates_in_each_agent>false</track_internalized_substrates_in_each_agent>
    </options>
  </microenvironment_setup>

  <cell_definitions>
    <cell_definition name="trophoblast" ID="0">
      <phenotype>
        <cycle code="6" name="flow_cytometry_separated_cycle_model">
          <phase_transition_rates units="1/min">
            <rate start_index="0" end_index="1" fixed_duration="false">0.0</rate>
            <rate start_index="1" end_index="2" fixed_duration="false">0.0</rate>
            <rate start_index="2" end_index="3" fixed_duration="false">0.0</rate>
            <rate start_index="3" end_index="0" fixed_duration="false">0.0</rate>
          </phase_transition_rates>
        </cycle>
        <death>
          <model code="100" name="apoptosis">
            <death_rate units="1/min">5.31667e-05</death_rate>
          </model>
        </death>
        <volume>
          <total units="micron^3">2494</total>
          <fluid_fraction units="dimensionless">0.75</fluid_fraction>
          <nuclear units="micron^3">540</nuclear>
        </volume>
        <mechanics>
          <cell_cell_adhesion_strength units="micron/min">0.4</cell_cell_adhesion_strength>
          <cell_cell_repulsion_strength units="micron/min">10.0</cell_cell_repulsion_strength>
        </mechanics>
        <motility>
          <speed units="micron/min">0.0</speed>
          <migration_bias units="dimensionless">0.0</migration_bias>
        </motility>
        <secretion>
          <substrate name="oxygen">
            <uptake_rate units="1/min">10.0</uptake_rate>
            <secretion_target units="substrate density">0</secretion_target>
          </substrate>
          <substrate name="glucose">
            <uptake_rate units="1/min">0.1</uptake_rate>
            <secretion_target units="substrate density">0</secretion_target>
          </substrate>
        </secretion>
      </phenotype>
    </cell_definition>
  </cell_definitions>

  <initial_conditions>
    <cell_positions type="csv" enabled="false">
      <folder>./config</folder>
      <filename>cells.csv</filename>
    </cell_positions>
  </initial_conditions>

  <!--
    User parameters come from nidus. Regenerate via:
      nidus export --format physiocell --output .
    Then `<xi:include href="nidus-parameters.xml"/>` or copy/paste the
    <user_parameters> block in.
  -->
  <user_parameters>
    <random_seed type="int" units="dimensionless">0</random_seed>
    <n_trophoblasts type="int" units="dimensionless"
                    description="Number of trophoblast agents seeded around the central villus">120</n_trophoblasts>
    <villus_radius type="double" units="micron"
                   description="Radius of the central villus cross-section">30.0</villus_radius>
    <!--
      The full set of mechanistic parameters lives in nidus-parameters.xml.
      Load that alongside this file (PhysiCell supports a second
      `--user-parameters` XML in 1.13+) so this stays small and the
      provenance-rich nidus block remains untouched.
    -->
  </user_parameters>

</PhysiCell_settings>
